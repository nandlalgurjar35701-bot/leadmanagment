<%- include('../layouts/header') %>

<div class="dashboard-container">
  <div class="container">

    <!-- Header Actions -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-5">
      <div>
        <h1 class="page-title mb-1"><i class="fa-solid fa-chart-column text-primary me-2"></i>CRM Reports & Analytics</h1>
        <p class="text-muted">Analyze sales representative performance, lead distribution status, and revenue conversion metrics.</p>
      </div>
      <div>
        <a href="/admin/export/csv" class="btn btn-success px-4 py-2.5 rounded-3 shadow-sm d-inline-flex align-items-center">
          <i class="fa-solid fa-file-excel me-2"></i> Export Database to CSV (Excel)
        </a>
      </div>
    </div>

    <!-- Analytics Cards -->
    <div class="row g-4 mb-5">
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <h6 class="text-muted small text-uppercase fw-bold">Total CRM Leads</h6>
          <h2 class="fw-bold mb-0 text-dark"><%= stats.totalLeads %></h2>
          <div class="mt-2 text-muted small">All history database</div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <h6 class="text-muted small text-uppercase fw-bold">Won Deals</h6>
          <h2 class="fw-bold mb-0 text-success"><%= stats.wonLeads %></h2>
          <div class="mt-2 text-muted small">Total client acquisitions</div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <h6 class="text-muted small text-uppercase fw-bold">Conversion Rate</h6>
          <% 
            const conversionRate = stats.totalLeads > 0 ? Math.round((stats.wonLeads / stats.totalLeads) * 100) : 0;
          %>
          <h2 class="fw-bold mb-0 text-primary"><%= conversionRate %>%</h2>
          <div class="mt-2 text-muted small">From first log to deal closure</div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <h6 class="text-muted small text-uppercase fw-bold">Total Revenue</h6>
          <h2 class="fw-bold mb-0 text-dark">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></h2>
          <div class="mt-2 text-muted small">Won deals value summary</div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-5">
      <!-- Sales Representatives Performance -->
      <div class="col-12">
        <div class="card stat-card border">
          <div class="card-header bg-dark text-white p-3">
            <h5 class="mb-0"><i class="fa-solid fa-ranking-star me-2"></i>Sales User Performance Breakdown</h5>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table align-middle mb-0" style="min-width: 600px;">
                <thead class="table-light">
                  <tr>
                    <th scope="col" class="ps-4">Sales Representative</th>
                    <th scope="col">Email</th>
                    <th scope="col">Total Assigned Leads</th>
                    <th scope="col">Won Deals</th>
                    <th scope="col">Conversion Rate</th>
                    <th scope="col" class="text-end pe-4">Revenue Generated</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (performance.length > 0) { %>
                    <% performance.forEach(function(agent) { %>
                      <tr>
                        <td class="ps-4 fw-semibold text-dark"><%= agent.name %></td>
                        <td class="text-muted small"><%= agent.email %></td>
                        <td class="fw-medium text-dark"><%= agent.totalLeads %></td>
                        <td class="text-success fw-bold"><%= agent.wonLeads %></td>
                        <td>
                          <% 
                            const rate = agent.totalLeads > 0 ? Math.round((agent.wonLeads / agent.totalLeads) * 100) : 0;
                            let progressColor = 'bg-danger';
                            if (rate >= 50) progressColor = 'bg-success';
                            else if (rate >= 20) progressColor = 'bg-warning';
                          %>
                          <div class="d-flex align-items-center gap-2">
                            <span class="small fw-bold text-dark"><%= rate %>%</span>
                            <div class="progress w-100" style="height: 6px;">
                              <div class="progress-bar <%= progressColor %>" role="progressbar" style="width: <%= rate %>%"></div>
                            </div>
                          </div>
                        </td>
                        <td class="text-end pe-4 fw-bold text-success">₹<%= agent.revenue.toLocaleString('en-IN') %></td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="6" class="text-center py-4 text-muted">No sales user statistics available.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <!-- Status Distribution Table -->
      <div class="col-md-6">
        <div class="card stat-card border h-100">
          <div class="card-header bg-light border-bottom p-3">
            <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-filter-list text-primary me-2"></i>Leads Status Distribution</h6>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th>Lead Status</th>
                    <th class="text-end">Count</th>
                    <th class="text-end" style="width: 40%;">Percentage</th>
                  </tr>
                </thead>
                <tbody>
                  <% 
                    // Sort status breakdown by count descending
                    const sortedStatus = [...statusBreakdown].sort((a,b) => b.count - a.count);
                  %>
                  <% if (sortedStatus.length > 0) { %>
                    <% sortedStatus.forEach(function(item) { %>
                      <% 
                        const pct = stats.totalLeads > 0 ? Math.round((item.count / stats.totalLeads) * 100) : 0;
                      %>
                      <tr>
                        <td>
                          <span class="small fw-medium text-dark"><%= item._id %></span>
                        </td>
                        <td class="text-end fw-bold"><%= item.count %></td>
                        <td class="text-end">
                          <span class="small text-muted"><%= pct %>%</span>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="text-center py-3 text-muted">No status data.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Lead Source Breakdown -->
      <div class="col-md-6">
        <div class="card stat-card border h-100">
          <div class="card-header bg-light border-bottom p-3">
            <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-bullhorn text-primary me-2"></i>Lead Source Conversion</h6>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th>Source Channel</th>
                    <th class="text-end">Count</th>
                    <th class="text-end" style="width: 40%;">Share</th>
                  </tr>
                </thead>
                <tbody>
                  <% 
                    const sortedSource = [...sourceBreakdown].sort((a,b) => b.count - a.count);
                  %>
                  <% if (sortedSource.length > 0) { %>
                    <% sortedSource.forEach(function(item) { %>
                      <% 
                        const pct = stats.totalLeads > 0 ? Math.round((item.count / stats.totalLeads) * 100) : 0;
                      %>
                      <tr>
                        <td>
                          <span class="small fw-semibold text-dark"><%= item._id %></span>
                        </td>
                        <td class="text-end fw-bold"><%= item.count %></td>
                        <td class="text-end">
                          <span class="small text-muted"><%= pct %>%</span>
                        </td>
                      </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="3" class="text-center py-3 text-muted">No lead source records.</td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Category Popularity -->
      <div class="col-12 mt-4">
        <div class="card stat-card border">
          <div class="card-header bg-light border-bottom p-3">
            <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-tags text-primary me-2"></i>Popular Website Category Inquiries</h6>
          </div>
          <div class="card-body p-4">
            <div class="d-flex flex-wrap gap-3">
              <% if (categoryBreakdown.length > 0) { %>
                <% categoryBreakdown.forEach(function(item) { %>
                  <div class="border rounded px-3 py-2 bg-light d-flex align-items-center gap-2">
                    <strong class="text-indigo small"><%= item._id %></strong>
                    <span class="badge bg-secondary rounded-pill small" style="font-size: 0.65rem;"><%= item.count %> Leads</span>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="text-muted small">No target website categories selected on any active leads.</div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>

<%- include('../layouts/footer') %>
