<%- include('../layouts/header') %>

<div class="dashboard-container">
  <div class="container">
    
    <div class="row align-items-center mb-5">
      <div class="col-md-8">
        <h1 class="page-title mb-1">Website Categories</h1>
        <p class="text-muted">Manage the categories for target websites to be pitched during cold calling.</p>
      </div>
    </div>

    <div class="row g-4">
      <!-- Categories Table List (Full Width) -->
      <div class="col-md-12">
        <div class="table-container shadow-sm border mt-0">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold m-0 text-dark"><i class="fa-solid fa-list text-primary me-2"></i>All Categories</h5>
            <button class="btn btn-sm btn-primary px-3 py-2 rounded-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
              <i class="fa-solid fa-circle-plus me-1"></i> Add New Category
            </button>
          </div>
          <div class="table-responsive">
            <table class="table table-custom align-middle">
              <thead>
                <tr>
                  <th scope="col" style="width: 60px;">#</th>
                  <th scope="col">Category Name</th>
                  <th scope="col" style="width: 100px;">Status</th>
                  <th scope="col">Demo Websites</th>
                  <th scope="col" class="text-center" style="width: 160px;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (categories.length > 0) { %>
                  <% categories.forEach(function(cat, index) { %>
                    <tr>
                      <td class="text-muted small"><%= index + 1 %></td>
                      <td>
                        <i class="fa-solid <%= cat.icon || 'fa-tags' %> text-primary me-2" style="width: 20px;"></i>
                        <strong class="text-dark"><%= cat.name %></strong>
                      </td>
                      <td>
                        <% if (cat.isActive !== false) { %>
                          <span class="badge bg-success-subtle text-success border border-success border-opacity-25 px-2.5 py-1.5" style="font-size: 0.75rem;">Active</span>
                        <% } else { %>
                          <span class="badge bg-danger-subtle text-danger border border-danger border-opacity-25 px-2.5 py-1.5" style="font-size: 0.75rem;">Inactive</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="badge bg-indigo-subtle text-indigo px-2.5 py-1.5" style="background-color: rgba(79, 70, 229, 0.08); font-size: 0.75rem;">
                          <i class="fa-solid fa-globe me-1 text-primary"></i><%= cat.urls ? cat.urls.length : 0 %> sites
                        </span>
                      </td>
                      <td class="text-center">
                        <div class="d-flex gap-1.5 justify-content-center">
                          <!-- Toggle Status Trigger -->
                          <form action="/admin/categories/toggle-status/<%= cat._id %>" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-sm <%= cat.isActive !== false ? 'btn-outline-warning' : 'btn-outline-success' %> px-2.5 rounded-2" title="<%= cat.isActive !== false ? 'Deactivate Category' : 'Activate Category' %>">
                              <i class="fa-solid <%= cat.isActive !== false ? 'fa-ban' : 'fa-circle-check' %>"></i>
                            </button>
                          </form>

                          <!-- Edit Category Trigger -->
                          <button class="btn btn-sm btn-outline-info px-2.5 rounded-2" 
                                  data-bs-toggle="modal" 
                                  data-bs-target="#editCategoryModal" 
                                  data-catid="<%= cat._id %>"
                                  data-catname="<%= cat.name %>"
                                  data-caticon="<%= cat.icon || 'fa-tags' %>"
                                  title="Edit Category">
                            <i class="fa-solid fa-pen-to-square"></i>
                          </button>

                          <!-- Manage Demos Trigger -->
                          <button class="btn btn-sm btn-outline-primary px-2.5 rounded-2" 
                                  data-bs-toggle="modal" 
                                  data-bs-target="#manageUrlsModal" 
                                  data-catid="<%= cat._id %>"
                                  data-catname="<%= cat.name %>"
                                  data-urls='<%= JSON.stringify(cat.urls || []) %>'
                                  title="Manage Demos">
                            <i class="fa-solid fa-laptop-code"></i>
                          </button>
                          
                          <form action="/admin/categories/delete/<%= cat._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete the category \'<%= cat.name %>\'?');" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger px-2.5 rounded-2" title="Delete Category">
                              <i class="fa-solid fa-trash-can"></i>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-5">
                      <div class="text-muted mb-2">
                        <i class="fa-solid fa-tags fa-2x"></i>
                      </div>
                      <h6 class="fw-bold">No Categories Found</h6>
                      <p class="text-muted small mb-0">The category collection is empty.</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Manage URLs Modal (Admin Privilege) -->
<div class="modal fade modal-custom" id="manageUrlsModal" tabindex="-1" aria-labelledby="manageUrlsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content shadow">
      <div class="modal-header">
        <h5 class="modal-title" id="manageUrlsModalLabel"><i class="fa-solid fa-laptop-code text-primary me-2"></i>Manage Website Demos</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-dark">
        <p class="text-muted small mb-4">Add or remove portfolio/reference websites that agents can pitch for category: <strong id="modal-cat-display" class="text-dark"></strong></p>
        
        <!-- Current URLs List -->
        <h6 class="fw-bold mb-3"><i class="fa-solid fa-globe text-secondary me-1"></i>Current Demo Websites</h6>
        <div id="demo-links-list" class="d-flex flex-column gap-2 mb-4" style="max-height: 250px; overflow-y: auto;">
          <!-- Dynamically injected -->
        </div>

        <!-- Add New URL Form -->
        <hr>
        <h6 class="fw-bold mb-3"><i class="fa-solid fa-circle-plus text-secondary me-1"></i>Add New Demo Website</h6>
        <form id="addUrlForm" method="POST" action="">
          <div class="row g-3">
            <div class="col-md-5 text-start">
              <label for="url-title" class="form-label small fw-medium">Website Title</label>
              <input type="text" class="form-control" id="url-title" name="title" placeholder="E.g., Beauty Salon Demo" required>
            </div>
            <div class="col-md-7 text-start">
              <label for="url-link" class="form-label small fw-medium">Website Link (URL)</label>
              <div class="input-group">
                <input type="url" class="form-control" id="url-link" name="link" placeholder="E.g., https://salon-demo.com" required>
                <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-plus me-1"></i>Add URL</button>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Edit Category Modal (Admin Privilege) -->
<div class="modal fade modal-custom" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow">
      <div class="modal-header">
        <h5 class="modal-title" id="editCategoryModalLabel"><i class="fa-solid fa-pen-to-square text-primary me-2"></i>Edit Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editCategoryForm" method="POST" action="">
        <div class="modal-body text-dark text-start">
          <div class="mb-3">
            <label for="edit-category-name" class="form-label small fw-medium">Category Name</label>
            <input type="text" class="form-control" id="edit-category-name" name="name" placeholder="E.g., Gym, Restaurant" required>
          </div>
          <div class="mb-3">
            <label for="edit-category-icon" class="form-label small fw-medium">Icon Class Name (Optional)</label>
            <input type="text" class="form-control" id="edit-category-icon" name="icon" placeholder="E.g., fa-scissors, fa-dumbbell">
            <div class="form-text small text-muted">Use standard <a href="https://fontawesome.com/search?o=r&m=free" target="_blank" class="text-decoration-none">FontAwesome Free</a> class names.</div>
          </div>
        </div>
        <div class="modal-footer border-0 bg-light py-3">
          <button type="button" class="btn btn-outline-secondary px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary px-4 rounded-3"><i class="fa-solid fa-circle-check me-1"></i>Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Add Category Modal (Admin Privilege) -->
<div class="modal fade modal-custom" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow">
      <div class="modal-header">
        <h5 class="modal-title" id="addCategoryModalLabel"><i class="fa-solid fa-circle-plus text-primary me-2"></i>Add New Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/admin/categories" method="POST">
        <div class="modal-body text-dark text-start">
          <div class="mb-3">
            <label for="new-category-name" class="form-label small fw-medium">Category Name</label>
            <input type="text" class="form-control" id="new-category-name" name="name" placeholder="E.g., Gym, Restaurant" required>
          </div>
          <div class="mb-3">
            <label for="new-category-icon" class="form-label small fw-medium">Icon Class Name (Optional)</label>
            <input type="text" class="form-control" id="new-category-icon" name="icon" placeholder="E.g., fa-scissors, fa-dumbbell">
            <div class="form-text small text-muted">Use standard <a href="https://fontawesome.com/search?o=r&m=free" target="_blank" class="text-decoration-none">FontAwesome Free</a> class names.</div>
          </div>
        </div>
        <div class="modal-footer border-0 bg-light py-3">
          <button type="button" class="btn btn-outline-secondary px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary px-4 rounded-3"><i class="fa-solid fa-circle-plus me-1"></i>Create Category</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const urlsModal = document.getElementById('manageUrlsModal');
    if (urlsModal) {
      urlsModal.addEventListener('show.bs.modal', function(event) {
        const button = event.relatedTarget;
        const catId = button.getAttribute('data-catid');
        const catName = button.getAttribute('data-catname');
        const urlsRaw = button.getAttribute('data-urls');
        
        const urls = JSON.parse(urlsRaw || '[]');
        
        const catDisplay = document.getElementById('modal-cat-display');
        const addForm = document.getElementById('addUrlForm');
        const listContainer = document.getElementById('demo-links-list');
        
        // Update display & form actions
        catDisplay.textContent = catName;
        addForm.action = '/admin/categories/add-url/' + catId;
        
        // Render links
        listContainer.innerHTML = '';
        if (urls.length > 0) {
          urls.forEach(function(u) {
            const row = document.createElement('div');
            row.className = 'd-flex justify-content-between align-items-center bg-light p-2.5 rounded border';
            row.innerHTML = `
              <div class="text-start">
                <strong class="text-dark small">${u.title || 'Demo Website'}</strong>
                <a href="${u.link}" target="_blank" class="d-block text-primary font-monospace small" style="font-size: 0.75rem;">${u.link}</a>
              </div>
              <form method="POST" action="/admin/categories/delete-url/${catId}/${u._id}" onsubmit="return confirm('Are you sure you want to remove this URL?');">
                <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2.5 rounded-2">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
              </form>
            `;
            listContainer.appendChild(row);
          });
        } else {
          listContainer.innerHTML = '<p class="text-muted small py-3 text-center my-0">No demo websites added for this category yet.</p>';
        }
      });
    }

    const editModal = document.getElementById('editCategoryModal');
    if (editModal) {
      editModal.addEventListener('show.bs.modal', function(event) {
        const button = event.relatedTarget;
        const catId = button.getAttribute('data-catid');
        const catName = button.getAttribute('data-catname');
        const catIcon = button.getAttribute('data-caticon');
        
        const form = document.getElementById('editCategoryForm');
        const nameInput = document.getElementById('edit-category-name');
        const iconInput = document.getElementById('edit-category-icon');
        
        form.action = '/admin/categories/edit/' + catId;
        nameInput.value = catName;
        iconInput.value = catIcon;
      });
    }
  });
</script>

<%- include('../layouts/footer') %>
