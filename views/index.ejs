<%- include('layouts/header') %>

<div class="dashboard-container">
  <div class="container">
    
    <!-- Welcome Header -->
    <div class="row align-items-center mb-4">
      <div class="col-md-8">
        <h1 class="page-title mb-1">Welcome, <%= user.name %>!</h1>
        <p class="text-muted">You are logged in as <span class="badge badge-custom <%= user.role === 'Admin' ? 'badge-admin' : 'badge-sales' %>"><%= user.role %></span>.</p>
      </div>
      <div class="col-md-4 text-md-end">
        <span class="text-muted small"><i class="fa-solid fa-clock me-1"></i> Today is <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      </div>
    </div>

    <!-- Phase 10: Reminder / Alert Notification Panel -->
    <% if (reminders.overdue.length > 0 || reminders.today.length > 0 || reminders.closingToday.length > 0) { %>
      <div class="row g-3 mb-5">
        <div class="col-12">
          <div class="card border shadow-sm">
            <div class="card-header bg-dark text-white p-3 d-flex align-items-center justify-content-between">
              <h6 class="mb-0"><i class="fa-solid fa-bell text-warning me-2 animate-bounce"></i>Reminders & Alerts</h6>
              <span class="badge bg-danger"><%= reminders.overdue.length + reminders.today.length + reminders.closingToday.length %> Actions Due</span>
            </div>
            <div class="card-body p-3">
              
              <!-- Overdue follow-ups -->
              <% if (reminders.overdue.length > 0) { %>
                <div class="alert alert-danger border-0 mb-3 shadow-none" role="alert">
                  <h6 class="fw-bold mb-2"><i class="fa-solid fa-circle-exclamation me-1"></i> Overdue Follow-ups (Alert 🔥)</h6>
                  <div class="d-flex flex-wrap gap-2">
                    <% reminders.overdue.forEach(function(lead) { %>
                      <a href="/leads/view/<%= lead._id %>" class="btn btn-sm btn-light border text-danger fw-semibold rounded-pill px-3 py-1">
                        <%= lead.name %> (<%= new Date(lead.nextFollowupDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>)
                      </a>
                    <% }); %>
                  </div>
                </div>
              <% } %>

              <!-- Due Today -->
              <% if (reminders.today.length > 0) { %>
                <div class="alert alert-warning border-0 mb-3 shadow-none text-dark" role="alert">
                  <h6 class="fw-bold mb-2"><i class="fa-solid fa-calendar-check me-1"></i> Scheduled Follow-ups Today</h6>
                  <div class="d-flex flex-wrap gap-2">
                    <% reminders.today.forEach(function(lead) { %>
                      <a href="/leads/view/<%= lead._id %>" class="btn btn-sm btn-white border text-dark fw-semibold rounded-pill px-3 py-1">
                        <%= lead.name %>
                      </a>
                    <% }); %>
                  </div>
                </div>
              <% } %>

              <!-- Deals expected to close today -->
              <% if (reminders.closingToday.length > 0) { %>
                <div class="alert alert-success border-0 mb-0 shadow-none text-dark" role="alert">
                  <h6 class="fw-bold mb-2"><i class="fa-solid fa-handshake me-1"></i> Deals Expected to Close Today! 🚀</h6>
                  <div class="d-flex flex-wrap gap-2">
                    <% reminders.closingToday.forEach(function(lead) { %>
                      <a href="/leads/view/<%= lead._id %>" class="btn btn-sm btn-light border text-success fw-semibold rounded-pill px-3 py-1">
                        <%= lead.name %> (₹<%= lead.budget.toLocaleString('en-IN') %>)
                      </a>
                    <% }); %>
                  </div>
                </div>
              <% } %>

            </div>
          </div>
        </div>
      </div>
    <% } %>

    <!-- Cards Section -->
    <h5 class="fw-bold mb-3 text-secondary"><i class="fa-solid fa-chart-line me-2"></i>CRM Performance Cards</h5>
    <div class="row g-4 mb-5">
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">Active leads</h6>
              <h3 class="fw-bold mb-0"><%= stats.totalLeads %></h3>
            </div>
            <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle">
              <i class="fa-solid fa-folder-open fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i><%= stats.wonLeads %> Won</span> / 
            <span class="text-danger"><%= stats.lostLeads %> Lost</span>
          </div>
        </div>
      </div>
      
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">Follow-ups Today</h6>
              <h3 class="fw-bold mb-0"><%= stats.todaysFollowups %></h3>
            </div>
            <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-circle">
              <i class="fa-solid fa-calendar-day fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            Actions scheduled for today
          </div>
        </div>
      </div>

      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">Interested Leads</h6>
              <h3 class="fw-bold mb-0"><%= stats.interestedLeads %></h3>
            </div>
            <div class="bg-info bg-opacity-10 text-info p-3 rounded-circle">
              <i class="fa-solid fa-fire text-danger fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            Includes <strong class="text-dark"><%= stats.readyToBuyLeads %> Ready to Buy</strong>
          </div>
        </div>
      </div>

      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">This Month Revenue</h6>
              <h3 class="fw-bold mb-0">₹<%= stats.thisMonthRevenue.toLocaleString('en-IN') %></h3>
            </div>
            <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle">
              <i class="fa-solid fa-indian-rupee-sign fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            Lifetime Won: <strong>₹<%= stats.totalRevenue.toLocaleString('en-IN') %></strong>
          </div>
        </div>
      </div>
    </div>

    <!-- Phase 7: Analytics Charts Grid -->
    <div class="row g-4 mb-5">
      <!-- Status breakdown pie chart -->
      <div class="col-md-6 col-lg-4">
        <div class="card stat-card border h-100">
          <div class="card-header bg-light border-bottom p-3">
            <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-pie text-indigo me-2"></i>Status Distribution</h6>
          </div>
          <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 250px;">
            <canvas id="statusChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Growth trends -->
      <div class="col-md-6 col-lg-4">
        <div class="card stat-card border h-100">
          <div class="card-header bg-light border-bottom p-3">
            <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-line text-indigo me-2"></i>Monthly Lead Growth</h6>
          </div>
          <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 250px;">
            <canvas id="growthChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Agent Performance -->
      <div class="col-lg-4">
        <div class="card stat-card border h-100">
          <div class="card-header bg-light border-bottom p-3">
            <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-column text-indigo me-2"></i>User Sales Metrics</h6>
          </div>
          <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 250px;">
            <canvas id="performanceChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Navigation Panels -->
    <div class="row g-4">
      <div class="col-lg-6">
        <div class="card stat-card h-100">
          <div class="card-header card-header-gradient p-3">
            <h5 class="mb-0"><i class="fa-solid fa-rocket me-2"></i>Quick Actions</h5>
          </div>
          <div class="card-body p-4">
            <p class="text-muted">Perform routine operations quickly based on your user privileges.</p>
            <div class="d-grid gap-3">
              <% if (user.role === 'Admin') { %>
                <a href="/admin/reports" class="btn btn-outline-primary text-start p-3 rounded-3 transition">
                  <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary p-2.5 rounded me-3">
                      <i class="fa-solid fa-chart-column fa-lg"></i>
                    </div>
                    <div>
                      <strong class="d-block text-dark">CRM Reports & CSV Export</strong>
                      <span class="small text-muted">Generate statistics charts, export leads to Excel/CSV worksheets.</span>
                    </div>
                  </div>
                </a>
                
                <a href="/admin/users" class="btn btn-outline-info text-start p-3 rounded-3 transition">
                  <div class="d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 text-info p-2.5 rounded me-3">
                      <i class="fa-solid fa-users-gear fa-lg"></i>
                    </div>
                    <div>
                      <strong class="d-block text-dark">Manage System Users</strong>
                      <span class="small text-muted">Create sales representatives, adjust roles, toggle access status.</span>
                    </div>
                  </div>
                </a>
              <% } %>
              
              <div class="row g-2">
                <div class="col-sm-6">
                  <a href="/leads" class="btn btn-outline-secondary w-100 text-start p-3 rounded-3 transition h-100">
                    <div class="d-flex align-items-center">
                      <div class="bg-secondary bg-opacity-10 text-secondary p-2.5 rounded me-3">
                        <i class="fa-solid fa-table-list fa-lg"></i>
                      </div>
                      <div>
                        <strong class="d-block text-dark">Table Pipeline</strong>
                        <span class="small text-muted" style="font-size: 0.75rem;">View table of leads and logs.</span>
                      </div>
                    </div>
                  </a>
                </div>
                <div class="col-sm-6">
                  <a href="/leads/kanban" class="btn btn-outline-indigo w-100 text-start p-3 rounded-3 transition h-100">
                    <div class="d-flex align-items-center">
                      <div class="bg-indigo-subtle text-indigo p-2.5 rounded me-3" style="background-color: rgba(79, 70, 229, 0.1);">
                        <i class="fa-solid fa-rectangle-list fa-lg"></i>
                      </div>
                      <div>
                        <strong class="d-block text-dark">Kanban Board</strong>
                        <span class="small text-muted" style="font-size: 0.75rem;">Drag-and-drop status update.</span>
                      </div>
                    </div>
                  </a>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card stat-card h-100">
          <div class="card-header bg-dark text-white p-3">
            <h5 class="mb-0"><i class="fa-solid fa-circle-info me-2"></i>CRM System Info</h5>
          </div>
          <div class="card-body p-4">
            <h6 class="fw-bold mb-3">CRM Expansion: Fully Functional</h6>
            <p>Our CRM Lead Module is complete. You can drag and drop leads on the Kanban board, trigger automatic alarms for overdue follow-ups, and review automated performance graphs and statistics reports.</p>
            
            <div class="alert alert-light border small" role="alert">
              <h6><i class="fa-solid fa-shield-halved me-1 text-primary"></i> Current Setup Summary:</h6>
              <ul class="mb-0 ps-3">
                <li>Kanban drag-and-drop state mapping</li>
                <li>Dynamic Hot / Warm / Cold Lead Scoring</li>
                <li>Interactive analytical reports charts rendering</li>
                <li>Excel & CSV downloads with full history logs</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Scripts to initialize Chart.js -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    // 1. Status Distribution
    const statusData = <%- JSON.stringify(charts.statusStats) %>;
    const statusCtx = document.getElementById('statusChart').getContext('2d');
    
    new Chart(statusCtx, {
      type: 'doughnut',
      data: {
        labels: statusData.map(d => d._id),
        datasets: [{
          data: statusData.map(d => d.count),
          backgroundColor: [
            '#4f46e5', '#10b981', '#f59e0b', '#3b82f6', 
            '#ec4899', '#8b5cf6', '#ef4444', '#64748b',
            '#06b6d4', '#14b8a6', '#f43f5e'
          ]
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          }
        }
      }
    });

    // 2. Growth Chart
    const growthData = <%- JSON.stringify(charts.growthStats) %>;
    const monthNames = ["", "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    const growthLabels = growthData.map(d => monthNames[d._id.month] + ' ' + d._id.year);
    const growthCtx = document.getElementById('growthChart').getContext('2d');
    
    new Chart(growthCtx, {
      type: 'line',
      data: {
        labels: growthLabels,
        datasets: [{
          label: 'New Leads Created',
          data: growthData.map(d => d.count),
          borderColor: '#4f46e5',
          backgroundColor: 'rgba(79, 70, 229, 0.1)',
          fill: true,
          tension: 0.3
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize: 1
            }
          }
        }
      }
    });

    // 3. Performance Chart
    const performanceData = <%- JSON.stringify(charts.performanceStats) %>;
    const perfCtx = document.getElementById('performanceChart').getContext('2d');
    
    new Chart(perfCtx, {
      type: 'bar',
      data: {
        labels: performanceData.map(d => d.name),
        datasets: [
          {
            label: 'Total Leads Assigned',
            data: performanceData.map(d => d.total),
            backgroundColor: 'rgba(99, 102, 241, 0.5)'
          },
          {
            label: 'Deals Won',
            data: performanceData.map(d => d.won),
            backgroundColor: '#10b981'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize: 1
            }
          }
        }
      }
    });
  });
</script>

<%- include('layouts/footer') %>
