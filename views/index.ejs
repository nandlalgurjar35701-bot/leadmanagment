<%- include('layouts/header') %>

<div class="dashboard-container">
  <div class="container">
    <div class="row align-items-center mb-5">
      <div class="col-md-8">
        <h1 class="page-title mb-1">Welcome, <%= user.name %>!</h1>
        <p class="text-muted">You are logged in as <span class="badge badge-custom <%= user.role === 'Admin' ? 'badge-admin' : 'badge-sales' %>"><%= user.role %></span>. Access your modules below.</p>
      </div>
      <div class="col-md-4 text-md-end">
        <span class="text-muted small"><i class="fa-solid fa-clock me-1"></i> Today is <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      </div>
    </div>

    <!-- Quick Stats Cards Section -->
    <div class="row g-4 mb-5">
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">Active leads</h6>
              <h3 class="fw-bold mb-0">0</h3>
            </div>
            <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle">
              <i class="fa-solid fa-folder-open fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            <span class="text-success"><i class="fa-solid fa-circle-check me-1"></i>0 Won</span> this month
          </div>
        </div>
      </div>
      
      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">Follow-ups Today</h6>
              <h3 class="fw-bold mb-0">0</h3>
            </div>
            <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-circle">
              <i class="fa-solid fa-calendar-day fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            <span class="text-warning"><i class="fa-solid fa-triangle-exclamation me-1"></i>0 Overdue</span> follow-ups
          </div>
        </div>
      </div>

      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">Conversion Rate</h6>
              <h3 class="fw-bold mb-0">0%</h3>
            </div>
            <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle">
              <i class="fa-solid fa-percent fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            From first call to final sale
          </div>
        </div>
      </div>

      <div class="col-md-3 col-sm-6">
        <div class="stat-card p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="text-muted small text-uppercase fw-bold">Total revenue</h6>
              <h3 class="fw-bold mb-0">₹0</h3>
            </div>
            <div class="bg-info bg-opacity-10 text-info p-3 rounded-circle">
              <i class="fa-solid fa-indian-rupee-sign fa-xl"></i>
            </div>
          </div>
          <div class="mt-3 small text-muted">
            Target closing rate tracker
          </div>
        </div>
      </div>
    </div>

    <!-- Features / Module Panels -->
    <div class="row g-4">
      <div class="col-lg-6">
        <div class="card stat-card h-100">
          <div class="card-header card-header-gradient p-3">
            <h5 class="mb-0"><i class="fa-solid fa-rocket me-2"></i>Quick Actions</h5>
          </div>
          <div class="card-body p-4">
            <p class="text-muted">Perform routine operations quickly based on your user privileges.</p>
            <div class="d-grid gap-3">
              <% if (user.role === 'Admin') { %>
                <a href="/admin/users" class="btn btn-outline-primary text-start p-3 rounded-3 transition">
                  <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary p-2.5 rounded me-3">
                      <i class="fa-solid fa-users-gear fa-lg"></i>
                    </div>
                    <div>
                      <strong class="d-block text-dark">Manage System Users</strong>
                      <span class="small text-muted">Create sales representatives, adjust roles, toggle access status.</span>
                    </div>
                  </div>
                </a>
              <% } %>
              
              <a href="#" class="btn btn-outline-secondary text-start p-3 rounded-3 transition opacity-75 cursor-not-allowed" style="pointer-events: none;">
                <div class="d-flex align-items-center">
                  <div class="bg-secondary bg-opacity-10 text-secondary p-2.5 rounded me-3">
                    <i class="fa-solid fa-address-book fa-lg"></i>
                  </div>
                  <div>
                    <strong class="d-block text-dark">Leads Pipeline (Phase 3 & 5)</strong>
                    <span class="small text-muted">View website selling pipelines and lead stages. Coming soon.</span>
                  </div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card stat-card h-100">
          <div class="card-header bg-dark text-white p-3">
            <h5 class="mb-0"><i class="fa-solid fa-circle-info me-2"></i>CRM System Info</h5>
          </div>
          <div class="card-body p-4">
            <h6 class="fw-bold mb-3">Phase 1 Status: Ready</h6>
            <p>Our CRM core is set up using Node.js, Express, MongoDB, EJS and Bootstrap 5. Password security uses bcryptjs and routing is secured by JSON Web Tokens (JWT) inside HTTP-only cookies.</p>
            
            <div class="alert alert-light border small" role="alert">
              <h6><i class="fa-solid fa-shield-halved me-1 text-primary"></i> Current Setup Summary:</h6>
              <ul class="mb-0 ps-3">
                <li>MVC Directory Structure initialized</li>
                <li>Mongoose User Collection mapped</li>
                <li>Autoseeded Admin credentials verified</li>
                <li>Search & Pagination scaffolding ready in Admin Management</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<%- include('layouts/footer') %>
