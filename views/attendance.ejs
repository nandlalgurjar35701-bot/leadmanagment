<%- include('layouts/header') %>

<div class="dashboard-container">
  <div class="container">

    <!-- Welcome and Page Header -->
    <div class="row align-items-center mb-4">
      <div class="col-md-8">
        <h1 class="page-title mb-1"><i class="fa-solid fa-business-time text-primary me-2"></i>Attendance Board</h1>
        <p class="text-muted">Clock in when starting your shift, and clock out when finished. Admins can view and export employee attendance logs.</p>
      </div>
      <div class="col-md-4 text-md-end">
        <span class="text-muted small"><i class="fa-solid fa-calendar me-1"></i> Today is <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      </div>
    </div>

    <!-- Clock In/Out Panel & My Attendance Stats -->
    <div class="row g-4 mb-5">
      <!-- Live Clock Terminal Card -->
      <div class="col-md-6 col-lg-5">
        <div class="card stat-card shadow-sm border-0 h-100 overflow-hidden">
          <div class="card-header bg-dark text-white p-3 d-flex align-items-center justify-content-between">
            <h6 class="mb-0 fw-bold"><i class="fa-solid fa-clock-rotate-left me-2 text-indigo"></i>Time Clock Terminal</h6>
            <span class="badge bg-secondary" id="live-time-badge">00:00:00</span>
          </div>
          <div class="card-body p-4 text-center d-flex flex-column justify-content-center align-items-center" style="min-height: 280px;">
            
            <% if (!todayLog) { %>
              <!-- Case: Not Clocked In Yet -->
              <div class="text-primary mb-3">
                <i class="fa-regular fa-clock fa-4x animate-bounce text-primary"></i>
              </div>
              <h4 class="fw-bold mb-2">You are NOT clocked in</h4>
              <p class="text-muted small mb-4">Click below to record your check-in time for today.</p>
              
              <form action="/attendance/clock-in" method="POST" class="w-100">
                <button type="submit" class="btn btn-primary btn-lg w-100 py-3 rounded-3 shadow">
                  <i class="fa-solid fa-right-to-bracket me-2"></i>Clock In
                </button>
              </form>

            <% } else if (todayLog && !todayLog.clockOut) { %>
              <!-- Case: Clocked In, waiting to Clock Out -->
              <div class="text-success mb-2">
                <i class="fa-solid fa-circle-notch fa-spin fa-4x text-success"></i>
              </div>
              <h4 class="fw-bold text-success mb-1">Shift Active</h4>
              
              <!-- Shift Live Timer -->
              <div class="my-3 py-2 px-4 bg-light rounded-pill border d-inline-block">
                <span class="text-muted small me-2">Duration:</span>
                <strong class="fs-4 text-dark" id="shift-timer" data-clockin="<%= todayLog.clockIn.getTime() %>">00h 00m 00s</strong>
              </div>

              <div class="text-muted small mb-4">
                <div>Logged in at: <strong><%= new Date(todayLog.clockIn).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %></strong></div>
                <% if (todayLog.clockInIp) { %>
                  <div class="text-xs">IP: <%= todayLog.clockInIp %></div>
                <% } %>
              </div>

              <form action="/attendance/clock-out" method="POST" class="w-100">
                <button type="submit" class="btn btn-danger btn-lg w-100 py-3 rounded-3 shadow">
                  <i class="fa-solid fa-right-from-bracket me-2"></i>Clock Out
                </button>
              </form>

            <% } else { %>
              <!-- Case: Completed for today -->
              <div class="text-indigo mb-3">
                <i class="fa-solid fa-circle-check fa-4x text-indigo"></i>
              </div>
              <h4 class="fw-bold mb-1">Shift Completed</h4>
              <p class="text-muted small mb-3">You have successfully clocked in and out today.</p>
              
              <div class="alert alert-success border-0 py-2 px-3 small w-100 text-start rounded-3" role="alert">
                <div class="d-flex justify-content-between mb-1">
                  <span><i class="fa-solid fa-arrow-right-to-bracket me-1 text-success"></i> Clock In:</span>
                  <strong><%= new Date(todayLog.clockIn).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></strong>
                </div>
                <div class="d-flex justify-content-between mb-1">
                  <span><i class="fa-solid fa-arrow-right-from-bracket me-1 text-danger"></i> Clock Out:</span>
                  <strong><%= new Date(todayLog.clockOut).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></strong>
                </div>
                <hr class="my-2 bg-success bg-opacity-25">
                <div class="d-flex justify-content-between">
                  <span><i class="fa-solid fa-hourglass-half me-1"></i> Total Time:</span>
                  <strong><%= Math.floor(todayLog.duration / 60) %>h <%= todayLog.duration % 60 %>m</strong>
                </div>
              </div>
            <% } %>

          </div>
        </div>
      </div>

      <!-- User Stats Summary & Quick Tip -->
      <div class="col-md-6 col-lg-7">
        <div class="card stat-card shadow-sm border-0 h-100">
          <div class="card-header bg-light border-bottom p-3">
            <h6 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-user-clock me-2 text-primary"></i>My Attendance Status</h6>
          </div>
          <div class="card-body p-4 d-flex flex-column justify-content-between">
            <div class="row g-3 mb-4">
              <div class="col-sm-6">
                <div class="p-3 bg-light rounded-3 border">
                  <span class="text-muted small text-uppercase fw-bold d-block">Status Today</span>
                  <% if (todayLog) { %>
                    <span class="badge badge-custom bg-success text-white mt-1">
                      <%= todayLog.status === 'Half Day' ? 'Half Day Present' : 'Present' %>
                    </span>
                  <% } else { %>
                    <span class="badge badge-custom bg-danger text-white mt-1">Not Clocked In</span>
                  <% } %>
                </div>
              </div>
              <div class="col-sm-6">
                <div class="p-3 bg-light rounded-3 border">
                  <span class="text-muted small text-uppercase fw-bold d-block">Total Logs (Month)</span>
                  <strong class="fs-4 text-dark"><%= history.length %> Logs</strong>
                </div>
              </div>
            </div>

            <div class="alert alert-light border small py-3" role="alert">
              <h6 class="fw-bold"><i class="fa-solid fa-lightbulb text-warning me-1"></i> Attendance Tips:</h6>
              <ul class="mb-0 ps-3 text-muted">
                <li>Remember to clock out at the end of your shift to log your duration properly.</li>
                <li>Working sessions less than 4 hours are classified as "Half Day".</li>
                <li>Please contact management if you require adjustments to your clock timings.</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Admin Dashboard (Visible to Admins Only) -->
    <% if (user.role === 'Admin') { %>
      <div class="card stat-card shadow-sm border-0 mb-5">
        <div class="card-header bg-dark text-white p-3 d-flex align-items-center justify-content-between">
          <h5 class="mb-0 fw-bold"><i class="fa-solid fa-users-gear text-indigo me-2"></i>Admin Attendance Board</h5>
          <span class="badge bg-indigo"><%= adminLogs.length %> Logs Found</span>
        </div>
        <div class="card-body p-4">
          
          <!-- Admin Statistics Row -->
          <% if (adminStats) { %>
            <div class="row g-3 mb-4 text-center">
              <div class="col-md-2.4 col-sm-4 col-6">
                <div class="p-2 border rounded-3 bg-light">
                  <span class="text-muted small d-block">Total Active Staff</span>
                  <h4 class="fw-bold mb-0 text-dark"><%= adminStats.totalEmployees %></h4>
                </div>
              </div>
              <div class="col-md-2.4 col-sm-4 col-6">
                <div class="p-2 border rounded-3 bg-light">
                  <span class="text-muted small d-block">Present Today</span>
                  <h4 class="fw-bold mb-0 text-success"><%= adminStats.present %></h4>
                </div>
              </div>
              <div class="col-md-2.4 col-sm-4 col-6">
                <div class="p-2 border rounded-3 bg-light">
                  <span class="text-muted small d-block">Currently Active</span>
                  <h4 class="fw-bold mb-0 text-primary"><%= adminStats.working %></h4>
                </div>
              </div>
              <div class="col-md-2.4 col-sm-4 col-6">
                <div class="p-2 border rounded-3 bg-light">
                  <span class="text-muted small d-block">Clocked Out Today</span>
                  <h4 class="fw-bold mb-0 text-secondary"><%= adminStats.clockedOut %></h4>
                </div>
              </div>
              <div class="col-md-2.4 col-sm-4 col-6">
                <div class="p-2 border rounded-3 bg-light">
                  <span class="text-muted small d-block">Absent Today</span>
                  <h4 class="fw-bold mb-0 text-danger"><%= adminStats.absent %></h4>
                </div>
              </div>
            </div>
          <% } %>

          <!-- Filters Row -->
          <form action="/attendance" method="GET" class="row g-3 mb-4 align-items-end">
            <div class="col-md-4">
              <label for="filter-date" class="form-label small fw-semibold text-muted">Select Date</label>
              <input type="date" class="form-control" id="filter-date" name="date" value="<%= selectedDate %>">
            </div>
            <div class="col-md-4">
              <label for="filter-user" class="form-label small fw-semibold text-muted">Select Employee</label>
              <select class="form-select" id="filter-user" name="userId">
                <option value="">-- All Employees --</option>
                <% allUsers.forEach(function(u) { %>
                  <option value="<%= u._id %>" <%= selectedUserId === u._id.toString() ? 'selected' : '' %>><%= u.name %> (<%= u.role %>)</option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
              <button type="submit" class="btn btn-primary flex-fill">
                <i class="fa-solid fa-filter me-1"></i> Filter
              </button>
              <a href="/attendance" class="btn btn-outline-secondary">
                <i class="fa-solid fa-rotate-left"></i>
              </a>
              <a href="/attendance/export?date=<%= selectedDate %>&userId=<%= selectedUserId %>" class="btn btn-success" title="Download Excel/CSV Report">
                <i class="fa-solid fa-file-csv"></i> Export
              </a>
            </div>
          </form>

          <!-- Admin Logs Table -->
          <div class="table-responsive">
            <table class="table table-custom align-middle">
              <thead>
                <tr>
                  <th>Employee Name</th>
                  <th>Role</th>
                  <th>Date</th>
                  <th>Clock In</th>
                  <th>Clock Out</th>
                  <th>Duration</th>
                  <th>Status</th>
                  <th>IP Address</th>
                </tr>
              </thead>
              <tbody>
                <% if (adminLogs.length === 0) { %>
                  <tr>
                    <td colspan="8" class="text-center text-muted py-4">No attendance records found for this selection.</td>
                  </tr>
                <% } else { %>
                  <% adminLogs.forEach(function(log) { %>
                    <tr>
                      <td>
                        <div class="fw-bold"><%= log.user ? log.user.name : 'Deleted User' %></div>
                        <span class="small text-muted"><%= log.user ? log.user.email : 'N/A' %></span>
                      </td>
                      <td>
                        <span class="badge badge-custom <%= log.user && log.user.role === 'Admin' ? 'badge-admin' : 'badge-sales' %>">
                          <%= log.user ? log.user.role : 'N/A' %>
                        </span>
                      </td>
                      <td class="fw-semibold text-dark"><%= log.dateString %></td>
                      <td>
                        <span class="text-success"><i class="fa-solid fa-arrow-right-to-bracket me-1 text-success"></i> <%= new Date(log.clockIn).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
                      </td>
                      <td>
                        <% if (log.clockOut) { %>
                          <span class="text-danger"><i class="fa-solid fa-arrow-right-from-bracket me-1 text-danger"></i> <%= new Date(log.clockOut).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
                        <% } else { %>
                          <span class="text-muted"><i class="fa-solid fa-spinner fa-spin text-muted me-1"></i> Active</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (log.clockOut) { %>
                          <%= Math.floor(log.duration / 60) %>h <%= log.duration % 60 %>m
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                      <td>
                        <% if (!log.clockOut) { %>
                          <span class="badge bg-primary">Working</span>
                        <% } else if (log.status === 'Half Day') { %>
                          <span class="badge bg-warning text-dark">Half Day</span>
                        <% } else { %>
                          <span class="badge bg-success">Present</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="small text-muted" style="font-size: 0.75rem;">
                          In: <%= log.clockInIp || 'N/A' %><br>
                          Out: <%= log.clockOutIp || 'N/A' %>
                        </span>
                      </td>
                    </tr>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>

        </div>
      </div>
    <% } %>

    <!-- Personal History Table (Visible to All Users) -->
    <div class="card stat-card shadow-sm border-0">
      <div class="card-header bg-light border-bottom p-3 d-flex align-items-center justify-content-between">
        <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>My Attendance History (Past 30 Days)</h5>
      </div>
      <div class="card-body p-4">
        <div class="table-responsive">
          <table class="table table-custom align-middle">
            <thead>
              <tr>
                <th>Date</th>
                <th>Clock In</th>
                <th>Clock Out</th>
                <th>Duration</th>
                <th>Status</th>
                <th>Location Details (IP)</th>
              </tr>
            </thead>
            <tbody>
              <% if (history.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center text-muted py-4">You have not logged any attendance yet.</td>
                </tr>
              <% } else { %>
                <% history.forEach(function(log) { %>
                  <tr>
                    <td class="fw-bold"><%= log.dateString %></td>
                    <td>
                      <span class="text-success"><i class="fa-solid fa-arrow-right-to-bracket me-1 text-success"></i> <%= new Date(log.clockIn).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
                    </td>
                    <td>
                      <% if (log.clockOut) { %>
                        <span class="text-danger"><i class="fa-solid fa-arrow-right-from-bracket me-1 text-danger"></i> <%= new Date(log.clockOut).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
                      <% } else { %>
                        <span class="text-muted"><i class="fa-solid fa-spinner fa-spin text-muted me-1"></i> Active</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (log.clockOut) { %>
                        <strong><%= Math.floor(log.duration / 60) %>h <%= log.duration % 60 %>m</strong>
                      </td>
                    <% } else { %>
                      -
                    <% } %>
                    <td>
                      <% if (!log.clockOut) { %>
                        <span class="badge bg-primary">Working</span>
                      <% } else if (log.status === 'Half Day') { %>
                        <span class="badge bg-warning text-dark">Half Day</span>
                      <% } else { %>
                        <span class="badge bg-success">Present</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="small text-muted" style="font-size: 0.75rem;">
                        In: <%= log.clockInIp || 'N/A' %> | Out: <%= log.clockOutIp || 'N/A' %>
                      </span>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // 1. Live ticking clock
    const liveTimeBadge = document.getElementById("live-time-badge");
    if (liveTimeBadge) {
      setInterval(() => {
        const now = new Date();
        liveTimeBadge.textContent = now.toLocaleTimeString('en-US');
      }, 1000);
    }

    // 2. Active shift duration timer
    const shiftTimer = document.getElementById("shift-timer");
    if (shiftTimer) {
      const clockInMs = parseInt(shiftTimer.getAttribute("data-clockin"));
      
      const updateTimer = () => {
        const nowMs = new Date().getTime();
        const diffMs = nowMs - clockInMs;
        
        if (diffMs < 0) {
          shiftTimer.textContent = "00h 00m 00s";
          return;
        }

        const totalSecs = Math.floor(diffMs / 1000);
        const hours = Math.floor(totalSecs / 3600);
        const mins = Math.floor((totalSecs % 3600) / 60);
        const secs = totalSecs % 60;
        
        const pad = (num) => String(num).padStart(2, '0');
        shiftTimer.textContent = `${pad(hours)}h ${pad(mins)}m ${pad(secs)}s`;
      };
      
      updateTimer();
      setInterval(updateTimer, 1000);
    }
  });
</script>

<%- include('layouts/footer') %>
