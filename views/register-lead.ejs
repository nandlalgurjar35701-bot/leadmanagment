<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Start Your Project | NexGen Tech Solutions</title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- FontAwesome Icons -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <!-- Google Fonts: Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">

  <style>
    :root {
      --primary-glow: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
      --bg-dark: #0f172a;
      --bg-card: rgba(30, 41, 59, 0.7);
      --border-color: rgba(255, 255, 255, 0.08);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-dark);
      background-image:
        radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(79, 70, 229, 0.15) 0px, transparent 50%);
      background-attachment: fixed;
      color: var(--text-main);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* IT Agency Navbar */
    .agency-navbar {
      background: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      padding: 18px 0;
    }

    .agency-brand {
      font-weight: 800;
      font-size: 1.4rem;
      letter-spacing: -0.5px;
      color: #fff !important;
      text-decoration: none;
    }

    .agency-brand span {
      background: linear-gradient(135deg, #818cf8 0%, #6366f1 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .nav-badge {
      font-size: 0.7rem;
      padding: 4px 8px;
      background: rgba(99, 102, 241, 0.15);
      color: #818cf8;
      border: 1px solid rgba(99, 102, 241, 0.3);
      border-radius: 50px;
      margin-left: 8px;
      font-weight: 600;
    }

    /* Glassmorphism Project Card */
    .project-card {
      background: var(--bg-card);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border-color);
      border-radius: 20px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .form-section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #818cf8;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 10px;
      margin-bottom: 25px;
    }

    /* Tech Style Input Fields */
    .form-label {
      color: var(--text-main);
      font-weight: 500;
      font-size: 0.9rem;
      margin-bottom: 8px;
    }

    .input-group-text {
      background-color: rgba(15, 23, 42, 0.6) !important;
      border: 1px solid var(--border-color) !important;
      color: var(--text-muted) !important;
    }

    .form-control,
    .form-select {
      background-color: rgba(15, 23, 42, 0.4) !important;
      border: 1px solid var(--border-color) !important;
      color: #fff !important;
      padding: 11px 15px;
      border-radius: 10px;
    }

    .form-control::placeholder {
      color: rgba(148, 163, 184, 0.5);
    }

    .form-control:focus,
    .form-select:focus {
      border-color: #6366f1 !important;
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2) !important;
      color: #fff !important;
    }

    /* Custom Category Grid Items */
    .cat-card {
      background: rgba(15, 23, 42, 0.4);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      transition: all 0.25s ease-in-out;
      cursor: pointer;
    }

    .cat-card:hover {
      border-color: rgba(99, 102, 241, 0.4);
      background: rgba(99, 102, 241, 0.05);
      transform: translateY(-2px);
    }

    .form-check-input:checked~.cat-label-wrapper {
      color: #818cf8;
    }

    .form-check-input {
      background-color: rgba(15, 23, 42, 0.6);
      border-color: var(--border-color);
    }

    .form-check-input:checked {
      background-color: #6366f1;
      border-color: #6366f1;
    }

    /* Submit Button Styling */
    .btn-submit-project {
      background: var(--primary-glow) !important;
      border: none !important;
      color: #fff !important;
      font-weight: 700;
      padding: 15px 40px;
      border-radius: 50px;
      transition: all 0.3s ease;
      box-shadow: 0 10px 20px rgba(99, 102, 241, 0.25);
    }

    .btn-submit-project:hover {
      transform: translateY(-2px);
      box-shadow: 0 15px 25px rgba(99, 102, 241, 0.4);
      color: #fff !important;
    }

    /* Footer */
    .agency-footer {
      background: #090d16;
      border-top: 1px solid var(--border-color);
      color: var(--text-muted);
      padding: 30px 0;
      margin-top: auto;
    }

    /* Micro animations */
    .animate-bounce-slow {
      animation: bounceSlow 4s infinite ease-in-out;
    }

    @keyframes bounceSlow {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-6px);
      }
    }
  </style>
</head>

<body>

  <!-- Custom IT Agency Navbar -->
  <nav class="navbar agency-navbar">
    <div class="container">
      <div class="d-flex align-items-center">
        <a class="agency-brand" href="#">
          <i class="fa-solid fa-code text-indigo me-2" style="color: #818cf8;"></i>NexGen<span>Tech</span>
        </a>
        <span class="nav-badge">Software & Digital Agency</span>
      </div>
    </div>
  </nav>

  <!-- Container for flash/alert messages (Self-contained) -->
  <div class="container mt-4">
    <% if (success_msg) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 shadow-lg text-dark bg-light-subtle"
        role="alert" style="backdrop-filter: blur(10px);">
        <div class="d-flex align-items-center">
          <i class="fa-solid fa-circle-check text-success fa-lg me-3"></i>
          <div>
            <strong class="d-block text-success">Submission Received!</strong>
            <span class="small text-white opacity-75">
              <%= success_msg %>
            </span>
          </div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
      <% } %>
        <% if (error_msg) { %>
          <div class="alert alert-danger alert-dismissible fade show border-0 shadow-lg text-dark bg-light-subtle"
            role="alert" style="backdrop-filter: blur(10px);">
            <div class="d-flex align-items-center">
              <i class="fa-solid fa-circle-exclamation text-danger fa-lg me-3"></i>
              <div>
                <strong class="d-block text-danger">Submission Error</strong>
                <span class="small text-white opacity-75">
                  <%= error_msg %>
                </span>
              </div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
          <% } %>
  </div>

  <!-- Main Discovery Form Content -->
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-9 col-xl-8">

        <div class="card project-card overflow-hidden">
          <!-- Compact Banner Hero -->
          <div class="text-center py-4 px-3 text-white"
            style="background: radial-gradient(circle at top, rgba(99, 102, 241, 0.2) 0%, transparent 70%); border-bottom: 1px solid var(--border-color);">
            <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
              <i class="fa-solid fa-laptop-code text-indigo fa-lg animate-bounce-slow" style="color: #818cf8;"></i>
              <h4 class="fw-bold m-0 text-white">Project Discovery & Quote</h4>
            </div>
            <p class="mb-0 opacity-75 text-white small px-md-3">
              Submit your requirements below to receive a custom solution & quote from our software engineers.
            </p>
          </div>

          <!-- Form Panel -->
          <div class="card-body p-4 p-md-5">
            <form action="/register-lead" method="POST" class="needs-validation" novalidate>
              <!-- Source tracking parameter -->
              <input type="hidden" name="leadSource" value="<%= leadSource %>">

              <!-- SECTION 1: Client Profile -->
              <h5 class="form-section-title">
                <i class="fa-solid fa-user-gear me-2"></i>1. Client & Business Profile
              </h5>

              <div class="row g-4 mb-5">
                <!-- Name -->
                <div class="col-md-6">
                  <label for="name" class="form-label">Full Name / Contact Person <span
                      class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                    <input type="text" class="form-control" id="name" name="name" placeholder="Enter full name"
                      required>
                    <div class="invalid-feedback">Name is required.</div>
                  </div>
                </div>

                <!-- Phone Number -->
                <div class="col-md-6">
                  <label for="mobileNumber" class="form-label">Contact Mobile Number <span
                      class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                    <input type="tel" class="form-control" id="mobileNumber" name="mobileNumber"
                      placeholder="Enter contact number" required>
                    <div class="invalid-feedback">Mobile number is required.</div>
                  </div>
                </div>

                <!-- Email -->
                <div class="col-md-6">
                  <label for="email" class="form-label">Business Email Address (Optional)</label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                    <input type="email" class="form-control" id="email" name="email" placeholder="name@yourcompany.com">
                  </div>
                </div>

                <!-- Business Name -->
                <div class="col-md-6">
                  <label for="storeName" class="form-label">Company / Brand Name (Optional)</label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-building"></i></span>
                    <input type="text" class="form-control" id="storeName" name="storeName"
                      placeholder="Enter business name">
                  </div>
                </div>
              </div>

              <!-- SECTION 2: Location -->
              <h5 class="form-section-title">
                <i class="fa-solid fa-map-location-dot me-2"></i>2. Location Details (Optional)
              </h5>

              <div class="row g-4 mb-5">
                <!-- City -->
                <div class="col-md-4">
                  <label for="city" class="form-label">City (Optional)</label>
                  <input type="text" class="form-control" id="city" name="city" placeholder="e.g. New York">
                </div>

                <!-- State -->
                <div class="col-md-4">
                  <label for="address" class="form-label">State / Region (Optional)</label>
                  <input type="text" class="form-control" id="address" name="address" placeholder="e.g. NY">
                </div>

                <!-- Country -->
                <div class="col-md-4">
                  <label for="country" class="form-label">Country (Optional)</label>
                  <input type="text" class="form-control" id="country" name="country" placeholder="e.g. United States"
                    value="India">
                </div>
              </div>

              <!-- SECTION 3: Project Architecture -->
              <h5 class="form-section-title">
                <i class="fa-solid fa-cubes me-2"></i>3. Project Scope & Category
              </h5>

              <!-- Business Category Checkbox Grid -->
              <div class="mb-4">
                <label class="form-label d-block mb-3">Industry Categories of Interest (Select all that apply) <span
                    class="text-danger">*</span></label>
                <div class="row g-3 px-1">
                  <% if (categories && categories.length> 0) { %>
                    <% categories.forEach(function(cat) { %>
                      <div class="col-sm-6 col-md-4">
                        <div class="cat-card h-100 p-3">
                          <div class="form-check d-flex align-items-center m-0">
                            <input class="form-check-input cursor-pointer me-3" type="checkbox" name="categories"
                              value="<%= cat.name %>" id="cat_<%= cat._id %>">
                            <label class="form-check-label w-100 cursor-pointer text-white small"
                              for="cat_<%= cat._id %>">
                              <i class="fa-solid <%= cat.icon || 'fa-tags' %> me-2" style="color: #818cf8;"></i>
                              <%= cat.name %>
                            </label>
                          </div>
                        </div>
                      </div>
                      <% }); %>
                        <% } else { %>
                          <div class="col-12 text-center py-3">
                            <p class="text-muted small italic">No standard tech categories found. Please explain your
                              sector in the requirements details.</p>
                          </div>
                          <% } %>
                </div>
              </div>

              <!-- Website/Application Scope Type -->
              <div class="mb-4 mt-4">
                <label for="websiteType" class="form-label">Required Digital Solution Type (Optional)</label>
                <div class="input-group">
                  <span class="input-group-text"><i class="fa-solid fa-laptop-code"></i></span>
                  <select class="form-select text-white" id="websiteType" name="websiteType">
                    <option value="" disabled selected>-- Select Solution Scope --</option>
                    <option value="Single Page / Landing Page">Single Page landing page / Promo site</option>
                    <option value="Multi-page Business Website">Multi-page corporate agency profile website</option>
                    <option value="E-Commerce Store">E-Commerce platform (Online shopping store & billing)</option>
                    <option value="Custom Web Application">Custom web application / Cloud SaaS platform</option>
                    <option value="Blog / Portfolio Website">Professional portfolio / Digital resume portal</option>
                    <option value="Other">Other / Custom Requirements</option>
                  </select>
                </div>
              </div>

              <!-- Tech Requirements details -->
              <div class="mb-4">
                <label for="notes" class="form-label">Brief Project Specifications / Integration Requirements
                  (Optional)</label>
                <textarea class="form-control" id="notes" name="notes" rows="4"
                  placeholder="Detail any technical requirements (e.g. database integrations, payment gateways, custom APIs, user dashboards)..."></textarea>
              </div>

              <!-- Submit Button & Trust Badges -->
              <div class="text-center mt-5">
                <!-- Trust Badges (Relocated here for better mobile visibility above the fold) -->
                <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
                  <span
                    class="badge bg-light bg-opacity-10 text-white border border-light border-opacity-10 px-3 py-2 rounded-pill small fw-medium">
                    <i class="fa-solid fa-check-double text-success me-1"></i> ISO 9001 Certified
                  </span>
                  <span
                    class="badge bg-light bg-opacity-10 text-white border border-light border-opacity-10 px-3 py-2 rounded-pill small fw-medium">
                    <i class="fa-solid fa-shield-halved text-info me-1"></i> Secure Project Portal
                  </span>
                  <span
                    class="badge bg-light bg-opacity-10 text-white border border-light border-opacity-10 px-3 py-2 rounded-pill small fw-medium">
                    <i class="fa-solid fa-file-contract text-warning me-1"></i> NDA Protected
                  </span>
                </div>

                <button type="submit" class="btn btn-submit-project btn-lg px-5 py-3 shadow-lg">
                  Submit Project Discovery Request <i class="fa-solid fa-circle-arrow-right ms-2"></i>
                </button>
                <p class="text-muted small mt-3"><i class="fa-solid fa-lock me-1"></i> Your specifications are covered
                  under standard corporate NDA policies.</p>
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- IT Agency Footer -->
  <footer class="agency-footer text-center">
    <div class="container">
      <p class="mb-2 text-white opacity-75">&copy; <%= new Date().getFullYear() %> NexGen Tech Solutions. All rights
          reserved.</p>
      <p class="mb-0 small text-muted">Web Design &bull; Custom Software Engineering &bull; Cloud Integrations &bull;
        Enterprise Solutions</p>
    </div>
  </footer>

  <!-- Bootstrap Bundle with Popper JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Enable Bootstrap 5 client-side validation
    (function () {
      'use strict'
      var forms = document.querySelectorAll('.needs-validation')
      Array.prototype.slice.call(forms)
        .forEach(function (form) {
          form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
              event.preventDefault()
              event.stopPropagation()
            }
            form.classList.add('was-validated')
          }, false)
        })
    })()
  </script>
</body>

</html>