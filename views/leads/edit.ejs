<%- include('../layouts/header') %>

<div class="dashboard-container">
  <div class="container">
    
    <div class="row justify-content-center">
      <div class="col-lg-10">
        
        <div class="mb-4">
          <a href="/leads/view/<%= lead._id %>" class="btn btn-sm btn-link text-secondary text-decoration-none ps-0">
            <i class="fa-solid fa-arrow-left-long me-1"></i> Back to Details
          </a>
          <h1 class="page-title mt-2 mb-1">Edit Lead: <%= lead.name %></h1>
          <p class="text-muted">Modify lead properties and transition client pipeline states.</p>
        </div>

        <div class="card stat-card border shadow-sm">
          <div class="card-header card-header-gradient p-3">
            <h5 class="mb-0"><i class="fa-solid fa-pen-to-square me-2"></i>Update Lead Form</h5>
          </div>
          <div class="card-body p-4 p-md-5">
            <form action="/leads/edit/<%= lead._id %>" method="POST">
              
              <!-- Section 1: Customer Info -->
              <h5 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-address-card me-2"></i>Contact Details</h5>
              <div class="row g-3 mb-4">
                <div class="col-md-6">
                  <label for="name" class="form-label fw-semibold">Customer Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control py-2.5" id="name" name="name" placeholder="Ramesh Kumar" value="<%= lead.name %>" required>
                </div>
                <div class="col-md-6">
                  <label for="email" class="form-label fw-semibold">Email Address</label>
                  <input type="email" class="form-control py-2.5" id="email" name="email" placeholder="ramesh@gmail.com" value="<%= lead.email || '' %>">
                </div>
                <div class="col-md-6">
                  <label for="mobileNumbers" class="form-label fw-semibold">Mobile Numbers <span class="text-danger">*</span></label>
                  <% 
                    const numbersList = lead.mobileNumbers.map(obj => obj.number).join(', ');
                  %>
                  <input type="text" class="form-control py-2.5" id="mobileNumbers" name="mobileNumbers" placeholder="9876543210, 9123456789" value="<%= numbersList %>" required>
                  <div class="form-text small">Separate multiple numbers with commas.</div>
                </div>
                <div class="col-md-6">
                  <label for="storeName" class="form-label fw-semibold">Store / Business Name</label>
                  <input type="text" class="form-control py-2.5" id="storeName" name="storeName" placeholder="Ramesh General Store" value="<%= lead.storeName || '' %>">
                </div>
              </div>

              <!-- Section 2: Address Info -->
              <h5 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-map-location-dot me-2"></i>Location</h5>
              <div class="row g-3 mb-4">
                <div class="col-md-6">
                  <label for="address" class="form-label fw-semibold">Street Address</label>
                  <input type="text" class="form-control py-2.5" id="address" name="address" placeholder="12, MG Road" value="<%= lead.address || '' %>">
                </div>
                <div class="col-md-3">
                  <label for="city" class="form-label fw-semibold">City</label>
                  <input type="text" class="form-control py-2.5" id="city" name="city" placeholder="Bangalore" value="<%= lead.city || '' %>">
                </div>
                <div class="col-md-3">
                  <label for="country" class="form-label fw-semibold">Country</label>
                  <input type="text" class="form-control py-2.5" id="country" name="country" placeholder="India" value="<%= lead.country || 'India' %>">
                </div>
              </div>

              <!-- Section 3: Project and Budget Info -->
              <h5 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-briefcase me-2"></i>Deal & Status Details</h5>
              <div class="row g-3 mb-4">
                <div class="col-md-3">
                  <label for="budget" class="form-label fw-semibold">Website Budget (₹)</label>
                  <input type="number" class="form-control py-2.5" id="budget" name="budget" placeholder="35000" min="0" value="<%= lead.budget %>">
                </div>
                <div class="col-md-3">
                  <label for="leadSource" class="form-label fw-semibold">Lead Source</label>
                  <select class="form-select py-2.5" id="leadSource" name="leadSource">
                    <option value="Cold Calling" <%= lead.leadSource === 'Cold Calling' ? 'selected' : '' %>>Cold Calling</option>
                    <option value="Facebook" <%= lead.leadSource === 'Facebook' ? 'selected' : '' %>>Facebook</option>
                    <option value="Instagram" <%= lead.leadSource === 'Instagram' ? 'selected' : '' %>>Instagram</option>
                    <option value="WhatsApp" <%= lead.leadSource === 'WhatsApp' ? 'selected' : '' %>>WhatsApp</option>
                    <option value="Reference" <%= lead.leadSource === 'Reference' ? 'selected' : '' %>>Reference</option>
                    <option value="Website" <%= lead.leadSource === 'Website' ? 'selected' : '' %>>Website</option>
                  </select>
                </div>
                <div class="col-md-3">
                  <label for="status" class="form-label fw-semibold">Pipeline Status</label>
                  <select class="form-select py-2.5" id="status" name="status">
                    <option value="New Lead" <%= lead.status === 'New Lead' ? 'selected' : '' %>>New Lead</option>
                    <option value="Contacted" <%= lead.status === 'Contacted' ? 'selected' : '' %>>Contacted</option>
                    <option value="Interested" <%= lead.status === 'Interested' ? 'selected' : '' %>>Interested</option>
                    <option value="Demo Scheduled" <%= lead.status === 'Demo Scheduled' ? 'selected' : '' %>>Demo Scheduled</option>
                    <option value="Proposal Sent" <%= lead.status === 'Proposal Sent' ? 'selected' : '' %>>Proposal Sent</option>
                    <option value="Negotiation" <%= lead.status === 'Negotiation' ? 'selected' : '' %>>Negotiation</option>
                    <option value="Ready To Buy" <%= lead.status === 'Ready To Buy' ? 'selected' : '' %>>Ready To Buy</option>
                    <option value="Won" <%= lead.status === 'Won' ? 'selected' : '' %>>Won</option>
                    <option value="Lost" <%= lead.status === 'Lost' ? 'selected' : '' %>>Lost</option>
                    <option value="Not Interested" <%= lead.status === 'Not Interested' ? 'selected' : '' %>>Not Interested</option>
                    <option value="Follow-up Required" <%= lead.status === 'Follow-up Required' ? 'selected' : '' %>>Follow-up Required</option>
                  </select>
                </div>
                <div class="col-md-3">
                  <label for="priority" class="form-label fw-semibold">Lead Priority</label>
                  <select class="form-select py-2.5" id="priority" name="priority">
                    <option value="Low" <%= lead.priority === 'Low' ? 'selected' : '' %>>Low</option>
                    <option value="Medium" <%= lead.priority === 'Medium' ? 'selected' : '' %>>Medium</option>
                    <option value="High" <%= lead.priority === 'High' ? 'selected' : '' %>>High</option>
                  </select>
                </div>
              </div>

              <!-- Section 4: Assign User (Admin Only) -->
              <% if (user.role === 'Admin') { %>
                <h5 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-user-check me-2"></i>Staff Assignment</h5>
                <div class="row mb-4">
                  <div class="col-md-6">
                    <label for="assignedTo" class="form-label fw-semibold">Assign Lead To Agent</label>
                    <select class="form-select py-2.5" id="assignedTo" name="assignedTo">
                      <option value="">Choose Agent...</option>
                      <% agents.forEach(function(agent) { %>
                        <option value="<%= agent._id %>" <%= lead.assignedTo && lead.assignedTo.toString() === agent._id.toString() ? 'selected' : '' %>><%= agent.name %> (<%= agent.role %>)</option>
                      <% }); %>
                    </select>
                  </div>
                </div>
              <% } %>

              <!-- Section 5: Website Categories checkboxes grid -->
              <h5 class="fw-bold mb-3 text-primary"><i class="fa-solid fa-tags me-2"></i>Website Categories</h5>
              <p class="text-muted small mb-3">Select the target categories for the website (select all that apply):</p>
              <div class="row g-2 mb-4 bg-light p-3 rounded border" style="max-height: 250px; overflow-y: auto;">
                <% categories.forEach(function(cat) { %>
                  <div class="col-md-4 col-sm-6">
                    <div class="form-check">
                      <% 
                        const isChecked = lead.categories.includes(cat.name);
                      %>
                      <input class="form-check-input" type="checkbox" name="categories" value="<%= cat.name %>" id="cat-<%= cat._id %>" <%= isChecked ? 'checked' : '' %>>
                      <label class="form-check-label text-dark fw-medium small" for="cat-<%= cat._id %>">
                        <%= cat.name %>
                      </label>
                    </div>
                  </div>
                <% }); %>
              </div>

              <!-- Section 6: Next Actions -->
              <h5 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-calendar-days me-2"></i>Next Steps</h5>
              <div class="row g-3 mb-4">
                <div class="col-md-6">
                  <label for="nextFollowupDate" class="form-label fw-semibold">Next Follow-up Date</label>
                  <% 
                    let formattedFollowup = '';
                    if (lead.nextFollowupDate) {
                      const d = new Date(lead.nextFollowupDate);
                      // Format to YYYY-MM-DDTHH:MM
                      const year = d.getFullYear();
                      const month = String(d.getMonth() + 1).padStart(2, '0');
                      const day = String(d.getDate()).padStart(2, '0');
                      const hours = String(d.getHours()).padStart(2, '0');
                      const minutes = String(d.getMinutes()).padStart(2, '0');
                      formattedFollowup = `${year}-${month}-${day}T${hours}:${minutes}`;
                    }
                  %>
                  <input type="datetime-local" class="form-control py-2.5" id="nextFollowupDate" name="nextFollowupDate" value="<%= formattedFollowup %>">
                </div>
                <div class="col-md-6">
                  <label for="expectedClosingDate" class="form-label fw-semibold">Expected Closing Date</label>
                  <% 
                    let formattedClosing = '';
                    if (lead.expectedClosingDate) {
                      const d = new Date(lead.expectedClosingDate);
                      const year = d.getFullYear();
                      const month = String(d.getMonth() + 1).padStart(2, '0');
                      const day = String(d.getDate()).padStart(2, '0');
                      formattedClosing = `${year}-${month}-${day}`;
                    }
                  %>
                  <input type="date" class="form-control py-2.5" id="expectedClosingDate" name="expectedClosingDate" value="<%= formattedClosing %>">
                </div>
              </div>

              <!-- Section 7: Notes -->
              <div class="mb-4">
                <label for="notes" class="form-label fw-semibold">Notes</label>
                <textarea class="form-control" id="notes" name="notes" rows="4" placeholder="Update client discussion..."><%= lead.notes %></textarea>
              </div>

              <!-- Action buttons -->
              <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                <a href="/leads/view/<%= lead._id %>" class="btn btn-outline-secondary px-4 py-2.5 rounded-3">Cancel</a>
                <button type="submit" class="btn btn-primary px-5 py-2.5 rounded-3">
                  <i class="fa-solid fa-circle-check me-1"></i> Update Lead
                </button>
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<%- include('../layouts/footer') %>
